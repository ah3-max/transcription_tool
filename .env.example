# 複製成 .env 後使用（.env 不進版控）。
# 端點一律 host.docker.internal：模型在 host 原生、app 在容器內（D-14）。

DATA_DIR=/data
DB_PATH=/data/index.db
APP_PORT=3600                 # 本機開發 3600；內網測試環境改 3610
BIND_HOST=0.0.0.0

LLM_ENDPOINT=http://host.docker.internal:1234/v1   # LM Studio（host）：gemma-4-31b
ASR_ENDPOINT=http://host.docker.internal:8000/v1   # vLLM（host）：Qwen3-ASR，待建·預設不啟動
LIVE_TR_ENDPOINT=http://host.docker.internal:8001  # NLLB（host）：即時翻譯，待建

RETENTION_DAYS=7
MAX_FILE_MIN=120
MAX_UPLOAD_GB=10               # 單次上傳總量上限(GB)、防亂塞；時長不擋(交未來切段)
RES_CAP=0.8
IDLE_RELEASE_MIN=10
